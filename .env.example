# 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 路径前缀配置（用于Nginx代理）
# ============================================
# 如果通过Nginx代理访问，设置路径前缀（如 /kanban）
# 如果直接访问，留空即可
BASE_PATH=/kanban

# ============================================
# 后端配置
# ============================================
# 后端监听端口
BACKEND_PORT=8000

# 后端监听地址（0.0.0.0表示监听所有网卡）
BACKEND_HOST=0.0.0.0

# ============================================
# 前端配置（开发模式）
# ============================================
# 前端开发服务器端口
FRONTEND_PORT=5175

# 前端开发服务器地址
FRONTEND_HOST=0.0.0.0

# 前端构建时的base路径（与BASE_PATH保持一致）
VITE_BASE_PATH=/kanban

# ============================================
# AI配置
# ============================================
# OpenAI API密钥（必填）
OPENAI_API_KEY=your-api-key-here

# OpenAI API基础URL（可选，用于代理或自定义端点）
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI模型名称（默认：gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# 数据库配置（可选）
# ============================================
# 默认SQLite数据库路径
# SQLITE_DB_PATH=./data/default.db

# MySQL配置示例（如果使用MySQL）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=kanban

# PostgreSQL配置示例（如果使用PostgreSQL）
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password
# POSTGRES_DATABASE=kanban

# ============================================
# 日志配置
# ============================================
# 日志级别（DEBUG, INFO, WARNING, ERROR）
# LOG_LEVEL=INFO

# ============================================
# 部署说明
# ============================================
# 1. 开发模式：
#    - 复制此文件为 .env
#    - 设置 OPENAI_API_KEY
#    - BASE_PATH 留空或设置为 /
#    - 运行 ./start.sh
#
# 2. 生产模式（通过Nginx代理）：
#    - 复制此文件为 .env
#    - 设置 OPENAI_API_KEY
#    - 设置 BASE_PATH（如 /kanban）
#    - 设置 VITE_BASE_PATH（与BASE_PATH一致）
#    - 运行 ./deploy.sh
#    - 配置Nginx（参考 nginx.conf.example）
